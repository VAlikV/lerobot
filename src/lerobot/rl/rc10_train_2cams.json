{
    "output_dir": null,
    "job_name": "rc10_sac",
    "resume": false,
    "seed": 1000,
    "num_workers": 4,
    "batch_size": 64,
    "steps": 100000,
    "eval_freq": 20000,
    "log_freq": 1,
    "save_checkpoint": true,
    "save_freq": 1000,
    "use_policy_training_preset": true,
    "optimizer": null,
    "scheduler": null,
    "wandb": {
        "enable": false,
        "project": "rc10_hilserl",
        "disable_artifact": true
    },
    "dataset": {
        "repo_id": "local/rc10_pick_place_cube_demos_2cams_cropped_resized",
        "use_imagenet_stats": false
    },
    "env": {
        "type": "gym_manipulator",
        "name": "rc10",
        "task": "pick_place_cube",
        "fps": 10,
        "robot": {
            "type": "rc10",
            "ip": "10.10.10.10",
            "rate_hz": 100,
            "velocity": 1.0,
            "acceleration": 1.0,
            "threshold_position": 0.001,
            "threshold_angle": 1.0,
            "gripper_port": "/dev/ttyUSB0",
            "gripper_baudrate": 115200,
            "cameras": {
                "front": {"type": "opencv", "index_or_path": 0, "width": 640, "height": 480, "fps": 30},
                "wrist": {"type": "opencv", "index_or_path": 4, "width": 640, "height": 480, "fps": 30}
            }
        },
        "teleop": {
            "type": "gamepad",
            "use_gripper": true
        },
        "processor": {
            "control_mode": "gamepad",
            "gripper": {
                "use_gripper": true,
                "gripper_penalty": -0.02
            },
            "reset": {
                "fixed_reset_joint_positions": [0.1, 0.420, 0.27, 3.14159, 0.0, 0.0],
                "reset_time_s": 7.0,
                "control_time_s": 15.0,
                "terminate_on_success": true,
                "randomization_xy": 0.02
            },
            "observation": {
                "display_cameras": false
            },
            "image_preprocessing": {
                "crop_params_dict": {
                    "observation.images.front": [32, 18, 92, 90],
                    "observation.images.wrist": [5, 7, 118, 104]
                },
                "resize_size": [128, 128]
            },
            "inverse_kinematics": {
                "end_effector_step_sizes": {"x": 0.01, "y": 0.01, "z": 0.01},
                "end_effector_bounds": {
                    "min": [-0.018, 0.3909, 0.224],
                    "max": [0.2007, 0.5781, 0.2921]
                }
            }
        },
        "features": {
            "observation.images.front": {
                "type": "VISUAL",
                "shape": [3, 128, 128]
            },
            "observation.images.wrist": {
                "type": "VISUAL",
                "shape": [3, 128, 128]
            },
            "observation.state": {
                "type": "STATE",
                "shape": [16]
            },
            "action": {
                "type": "ACTION",
                "shape": [3]
            }
        },
        "features_map": {
            "observation.images.front": "observation.images.front",
            "observation.images.wrist": "observation.images.wrist",
            "observation.state": "observation.state",
            "action": "action"
        }
    },
    "policy": {
        "type": "sac",
        "n_obs_steps": 1,
        "normalization_mapping": {
            "VISUAL": "MEAN_STD",
            "STATE": "MIN_MAX",
            "ENV": "MIN_MAX",
            "ACTION": "MIN_MAX"
        },
        "input_features": {
            "observation.images.front": {
                "type": "VISUAL",
                "shape": [3, 128, 128]
            },
            "observation.images.wrist": {
                "type": "VISUAL",
                "shape": [3, 128, 128]
            },
            "observation.state": {
                "type": "STATE",
                "shape": [16]
            }
        },
        "output_features": {
            "action": {
                "type": "ACTION",
                "shape": [3]
            }
        },
        "device": "cuda",
        "use_amp": true,
        "dataset_stats": {
            "observation.images.front": {
                "mean": [0.485, 0.456, 0.406],
                "std": [0.229, 0.224, 0.225]
            },
            "observation.images.wrist": {
                "mean": [0.485, 0.456, 0.406],
                "std": [0.229, 0.224, 0.225]
            },
            "observation.state": {
                "min": [-2.3574, -1.9281, 2.2089, -2.4121, -1.5723, -0.8008, -0.187, -0.1276, -0.1268, -0.158, -0.0039, -0.191, 0.0, -0.018, 0.3909, 0.224],
                "max": [-1.8431, -1.4336, 2.6069, -2.2135, -1.569, -0.2865, 0.1393, 0.1521, 0.1133, 0.1467, 0.0114, 0.1383, 1.0, 0.2007, 0.5781, 0.2921]
            },
            "action": {
                "min": [-1.0, -1.0, -1.0],
                "max": [1.0, 1.0, 1.0]
            }
        },
        "repo_id": "local/rc10_pick_cube",
        "storage_device": "cpu",
        "vision_encoder_name": "helper2424/resnet10",
        "freeze_vision_encoder": true,
        "image_encoder_hidden_dim": 32,
        "shared_encoder": true,
        "online_steps": 1000000,
        "online_buffer_capacity": 100000,
        "offline_buffer_capacity": 100000,
        "online_step_before_learning": 100,
        "policy_update_freq": 1,
        "discount": 0.97,
        "temperature_init": 0.01,
        "num_critics": 2,
        "num_subsample_critics": null,
        "critic_lr": 0.0003,
        "actor_lr": 0.0003,
        "temperature_lr": 0.0003,
        "critic_target_update_weight": 0.005,
        "utd_ratio": 2,
        "state_encoder_hidden_dim": 256,
        "latent_dim": 64,
        "target_entropy": null,
        "use_backup_entropy": true,
        "grad_clip_norm": 10.0,
        "num_discrete_actions": 3,
        "critic_network_kwargs": {
            "hidden_dims": [256, 256],
            "activate_final": true,
            "final_activation": null
        },
        "actor_network_kwargs": {
            "hidden_dims": [256, 256],
            "activate_final": true
        },
        "policy_kwargs": {
            "use_tanh_squash": true,
            "std_min": 1e-5,
            "std_max": 5,
            "init_final": 0.05
        },
        "actor_learner_config": {
            "learner_host": "127.0.0.1",
            "learner_port": 50051,
            "policy_parameters_push_frequency": 4
        },
        "concurrency": {
            "actor": "processes",
            "learner": "processes"
        }
    }
}
